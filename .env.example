# Flask
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=false
HOST=127.0.0.1
PORT=5000
# Set FLASK_USE_RELOADER=true only if you want auto-reload (can break on Windows briefly)
FLASK_USE_RELOADER=false

# Database
DATABASE_PATH=instance/osint.db

# Async checker
MAX_CONCURRENT_REQUESTS=25
REQUEST_TIMEOUT=10
USER_AGENT=OSINT-Username-Finder/1.0 (Educational Research Tool)

# Rate limiting
RATE_LIMIT_DEFAULT=10 per minute
RATE_LIMIT_SEARCH=5 per minute

# Screenshots (requires: playwright install chromium)
SCREENSHOTS_ENABLED=true
SCREENSHOT_TIMEOUT=15000
