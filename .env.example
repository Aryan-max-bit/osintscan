# Flask (local development only — Render sets RENDER=true and PORT automatically)
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=false
FLASK_ENV=development
HOST=127.0.0.1
PORT=5000
FLASK_USE_RELOADER=false

# Render: do not set HOST — platform uses 0.0.0.0 via gunicorn in render.yaml
# Render Start Command: gunicorn --bind 0.0.0.0:$PORT wsgi:app

# Database
DATABASE_PATH=instance/osint.db

# Async checker
MAX_CONCURRENT_REQUESTS=25
REQUEST_TIMEOUT=10
USER_AGENT=OSINT-Username-Finder/1.0 (Educational Research Tool)

# Rate limiting
RATE_LIMIT_DEFAULT=10 per minute
RATE_LIMIT_SEARCH=5 per minute

# Screenshots (requires: playwright install chromium)
SCREENSHOTS_ENABLED=true
SCREENSHOT_TIMEOUT=15000
